{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/stats", "dest": "/api/stats.py" },
    { "src": "/api/reviews", "dest": "/api/reviews.py" },
    { "src": "/api/csat", "dest": "/api/csat.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}